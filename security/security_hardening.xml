<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- ============================================================
         ENHANCED RECORD RULES — State-based Access Control
         These supplement the global multi-company rules from
         record_rules.xml with workflow state checks.
         ============================================================ -->

    <!-- Allocation: Only GM/MD can approve/reject submitted allocations -->
    <record id="rule_nn_fund_allocation_approve" model="ir.rule">
      <field name="name">Allocation: Approve only by GM/MD approvers</field>
      <field name="model_id" ref="model_nn_fund_allocation"/>
      <field name="groups" eval="[(4, ref('group_gm_approver')), (4, ref('group_md_approver')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[('state', 'in', ('submitted', 'pending_approval'))]</field>
    </record>

    <!-- Allocation: Only creator/admin can delete draft allocations -->
    <record id="rule_nn_fund_allocation_delete" model="ir.rule">
      <field name="name">Allocation: Delete only drafts by creator</field>
      <field name="model_id" ref="model_nn_fund_allocation"/>
      <field name="groups" eval="[(4, ref('group_fund_user')), (4, ref('group_finance_user')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="1"/>
      <field name="perm_unlink" eval="1"/>
      <field name="domain_force">['|', ('requested_by', '=', user.id), ('state', 'not in', ('draft',))]</field>
    </record>

    <!-- Requisition: Only GM/MD can approve submitted requisitions -->
    <record id="rule_nn_fund_requisition_approve" model="ir.rule">
      <field name="name">Requisition: Approve only by GM/MD approvers</field>
      <field name="model_id" ref="model_nn_fund_requisition"/>
      <field name="groups" eval="[(4, ref('group_gm_approver')), (4, ref('group_md_approver')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[('state', 'in', ('submitted', 'pending_approval'))]</field>
    </record>

    <!-- Transfer: Approve only by GM/MD approvers -->
    <record id="rule_nn_fund_transfer_approve" model="ir.rule">
      <field name="name">Transfer: Approve only by GM/MD approvers</field>
      <field name="model_id" ref="model_nn_fund_transfer"/>
      <field name="groups" eval="[(4, ref('group_gm_approver')), (4, ref('group_md_approver')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[('state', 'in', ('submitted', 'pending_approval'))]</field>
    </record>

    <!-- Bill: Only creator/admin can cancel own bills -->
    <record id="rule_nn_fund_bill_cancel" model="ir.rule">
      <field name="name">Bill: Cancel only by creator</field>
      <field name="model_id" ref="model_nn_fund_bill"/>
      <field name="groups" eval="[(4, ref('group_fund_user')), (4, ref('group_finance_user')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="1"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[('create_uid', '=', user.id), ('state', '=', 'draft')]</field>
    </record>

    <!-- Ledger: Read-only for non-administrators -->
    <record id="rule_nn_fund_ledger_readonly" model="ir.rule">
      <field name="name">Ledger: Read-only for non-administrators</field>
      <field name="model_id" ref="model_nn_fund_ledger"/>
      <field name="groups" eval="[(4, ref('group_fund_user')), (4, ref('group_finance_user')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="0"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Approval History: Read-only for non-administrators -->
    <record id="rule_nn_approval_history_readonly" model="ir.rule">
      <field name="name">Approval History: Read-only for non-administrators</field>
      <field name="model_id" ref="model_nn_approval_history"/>
      <field name="groups" eval="[(4, ref('group_fund_user')), (4, ref('group_finance_user')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="0"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Incoming Fund: Finance/Admin can write to draft (to confirm), pending_verification (to verify),
         and confirmed (for auto-save / notes). The Python write() override in models/incoming_fund.py
         protects critical fields on confirmed records. Reversed records remain write-blocked.
         perm_read=0 means this rule does NOT restrict reads — the global multi-company rule handles that. -->
    <record id="rule_nn_incoming_fund_verify" model="ir.rule">
      <field name="name">Incoming Fund: Verify only by Finance/Admin</field>
      <field name="model_id" ref="model_nn_incoming_fund"/>
      <field name="groups" eval="[(4, ref('group_finance_user')), (4, ref('group_fund_administrator'))]"/>
      <field name="perm_read" eval="0"/>
      <field name="perm_write" eval="1"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">['|', ('state', 'in', ('pending_verification', 'confirmed')), ('state', '=', 'draft')]</field>
    </record>

    <!-- Bank Email Parser: Only admin can write -->
    <record id="rule_nn_bank_email_parser_write" model="ir.rule">
      <field name="name">Bank Email Parser: Only admin can modify</field>
      <field name="model_id" ref="model_nn_bank_email_parser"/>
      <field name="groups" eval="[(4, ref('group_finance_user')), (4, ref('group_fund_user')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="0"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Audit Log: Read-only for non-administrators -->
    <record id="rule_nn_audit_log_readonly" model="ir.rule">
      <field name="name">Audit Log: Read-only for non-administrators</field>
      <field name="model_id" ref="model_nn_audit_log"/>
      <field name="groups" eval="[(4, ref('group_fund_user')), (4, ref('group_finance_user')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
      <field name="perm_read" eval="1"/>
      <field name="perm_write" eval="0"/>
      <field name="perm_create" eval="0"/>
      <field name="perm_unlink" eval="0"/>
      <field name="domain_force">[(1, '=', 1)]</field>
    </record>

  </data>
</odoo>
