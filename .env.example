#================================================================
# NN Fund Management — Environment Configuration
# Copy to .env and fill in all values before deployment
#================================================================

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=nn_fund_management
DB_USER=odoo
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_FILTER=nn_fund_management.*

# --- Odoo Admin ---
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Performance ---
WORKERS=4
MAX_CRON_THREADS=2
LIMIT_TIME_CPU=600
LIMIT_TIME_REAL=1200
LIMIT_MEMORY_SOFT=2684354560
LIMIT_MEMORY_HARD=4294967296
LIMIT_REQUEST=8192
SESSION_TTL=3600

# --- Server ---
LIST_DB=False
PROXY_MODE=True
LOG_LEVEL=info
RUN_MIGRATIONS=true

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=odoo@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_SSL=False
EMAIL_FROM=odoo@example.com

# --- SSL / Domain ---
DOMAIN_NAME=fund-management.example.com
SSL_EMAIL=admin@example.com

# --- Backup ---
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backup

# --- S3 Backup (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nn-fund-backups
AWS_S3_ENDPOINT=

# --- Docker Swarm ---
ODOO_REPLICAS=2
