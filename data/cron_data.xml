<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- ============================================================
         DAILY BALANCE VALIDATION — Runs every night at 1:00 AM
         Validates that all fund account balances match ledger aggregates
         Logs discrepancies to audit log for investigation
         ============================================================ -->
    <record id="cron_daily_balance_validation" model="ir.cron">
      <field name="name">Daily Balance Validation</field>
      <field name="model_id" ref="model_nn_fund_account"/>
      <field name="state">code</field>
      <field name="code">model.cron_validate_balances()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">5</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         DAILY AUDIT VALIDATION — Runs every night at 2:00 AM
         Verifies audit log completeness: every workflow transition
         must have a corresponding audit log entry
         ============================================================ -->
    <record id="cron_daily_audit_validation" model="ir.cron">
      <field name="name">Daily Audit Validation</field>
      <field name="model_id" ref="model_nn_audit_log"/>
      <field name="state">code</field>
      <field name="code">model.cron_validate_audit_logs()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">10</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=2)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         PENDING APPROVAL REMINDER — Runs every hour
         Sends email reminders for requests pending approval for
         more than 24 hours
         ============================================================ -->
    <record id="cron_pending_approval_reminder" model="ir.cron">
      <field name="name">Pending Approval Reminder</field>
      <field name="model_id" ref="model_nn_fund_allocation"/>
      <field name="state">code</field>
      <field name="code">model.cron_remind_pending_approvals()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">hours</field>

      <field name="active">True</field>
      <field name="priority">15</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         EXPIRED PENDING REQUEST ALERT — Runs daily at 3:00 AM
         Marks requests pending for more than 7 days as expired
         ============================================================ -->
    <record id="cron_expired_pending_request" model="ir.cron">
      <field name="name">Expired Pending Request Alert</field>
      <field name="model_id" ref="model_nn_fund_requisition"/>
      <field name="state">code</field>
      <field name="code">model.cron_expire_stale_requests()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">20</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=3)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         REQUISITION NEAR EXHAUSTION ALERT — Runs daily at 4:00 AM
         Alerts when remaining amount drops below 10% of approved
         ============================================================ -->
    <record id="cron_requisition_near_exhaustion" model="ir.cron">
      <field name="name">Requisition Near Exhaustion Alert</field>
      <field name="model_id" ref="model_nn_fund_requisition"/>
      <field name="state">code</field>
      <field name="code">model.cron_alert_near_exhaustion()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">25</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=4)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         MONTHLY LEDGER SUMMARY — Runs 1st of month at 5:00 AM
         Generates monthly summary report of all ledger activity
         ============================================================ -->
    <record id="cron_monthly_ledger_summary" model="ir.cron">
      <field name="name">Monthly Ledger Summary</field>
      <field name="model_id" ref="model_nn_fund_ledger"/>
      <field name="state">code</field>
      <field name="code">model.cron_generate_monthly_summary()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">months</field>

      <field name="active">True</field>
      <field name="priority">30</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(day=1, hour=5, minute=0)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         MONTHLY PROJECT BALANCE REPORT — Runs 1st of month at 6:00 AM
         Generates project-wise balance report
         ============================================================ -->
    <record id="cron_monthly_project_report" model="ir.cron">
      <field name="name">Monthly Project Balance Report</field>
      <field name="model_id" ref="model_nn_project"/>
      <field name="state">code</field>
      <field name="code">model.cron_generate_monthly_report()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">months</field>

      <field name="active">True</field>
      <field name="priority">35</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(day=1, hour=6, minute=0)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         FAILED EMAIL REPROCESSING — Runs every 30 minutes
         Retries parsing failed bank email transactions
         ============================================================ -->
    <record id="cron_failed_email_reprocess" model="ir.cron">
      <field name="name">Failed Email Reprocessing</field>
      <field name="model_id" ref="model_nn_bank_email_parser"/>
      <field name="state">code</field>
      <field name="code">model.cron_reprocess_failed_emails()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">30</field>
      <field name="interval_type">minutes</field>

      <field name="active">True</field>
      <field name="priority">40</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(minutes=30)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         LOW BALANCE ALERT — Runs daily at 7:00 AM
         Alerts when fund account balance drops below configured threshold
         ============================================================ -->
    <record id="cron_low_balance_alert" model="ir.cron">
      <field name="name">Low Balance Alert</field>
      <field name="model_id" ref="model_nn_fund_account"/>
      <field name="state">code</field>
      <field name="code">model.cron_alert_low_balance()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">45</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=7)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         EMAIL LOG CLEANUP — Runs daily at 3:00 AM
         Deletes old bank email logs (success > 90d, failed > 180d)
         ============================================================ -->
    <record id="cron_email_log_cleanup" model="ir.cron">
      <field name="name">Email Log Cleanup</field>
      <field name="model_id" ref="model_nn_bank_email_parser"/>
      <field name="state">code</field>
      <field name="code">model.cron_clean_old_logs()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">50</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=3)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         NIGHTLY LEDGER RECONCILIATION — Runs daily at 12:00 AM
         Full reconciliation: compares stored vs ledger-derived balances,
         detects duplicates, orphan entries, negative balances, and
         mismatches. Blocks operations if critical imbalance found.
         ============================================================ -->
    <record id="cron_nightly_reconciliation" model="ir.cron">
      <field name="name">Nightly Ledger Reconciliation</field>
      <field name="model_id" ref="model_nn_ledger_reconciliation"/>
      <field name="state">code</field>
      <field name="code">model.cron_nightly_reconciliation()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">1</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=0)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

    <!-- ============================================================
         CRON 10: API Idempotency Key Cleanup
         ============================================================ -->
    <record id="cron_clean_idempotency_keys" model="ir.cron">
      <field name="name">Clean Expired API Idempotency Keys</field>
      <field name="model_id" ref="model_nn_api_idempotency_key"/>
      <field name="state">code</field>
      <field name="code">model.cron_clean_expired_keys()</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>

      <field name="active">True</field>
      <field name="priority">20</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=6)).strftime('%Y-%m-%d %H:%M:%S')"/>

    </record>

  </data>
</odoo>
