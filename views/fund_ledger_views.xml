<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_ledger_tree" model="ir.ui.view">
        <field name="name">nn.fund.ledger.tree</field>
        <field name="model">nn.fund.ledger</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="reference"/>
                <field name="transaction_type"/>
                <field name="fund_account_id"/>
                <field name="debit" widget="monetary" sum="Total Debit"/>
                <field name="credit" widget="monetary" sum="Total Credit"/>
                <field name="amount" widget="monetary" sum="Total Amount"/>
                <field name="state"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nn_fund_ledger_form" model="ir.ui.view">
        <field name="name">nn.fund.ledger.form</field>
        <field name="model">nn.fund.ledger</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post" type="object"
                            string="Post" invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_reverse" type="object"
                            string="Reverse" invisible="state != 'posted'"
                            class="btn-warning"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="reference"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="transaction_type"/>
                            <field name="fund_account_id"/>
                            <field name="project_id"/>
                            <field name="expense_head_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="debit" widget="monetary"/>
                            <field name="credit" widget="monetary"/>
                            <field name="amount" widget="monetary"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <group string="Source Information">
                        <field name="reference_model"/>
                        <field name="reference_id"/>
                    </group>
                    <group string="Reversal Info" invisible="not reversal_ledger_id">
                        <field name="reversal_ledger_id"/>
                    </group>
                    <notebook>
                        <page string="Note">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_ledger_search" model="ir.ui.view">
        <field name="name">nn.fund.ledger.search</field>
        <field name="model">nn.fund.ledger</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="transaction_type"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <filter name="posted" string="Posted" domain="[('state','=','posted')]"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="incoming" string="Incoming" domain="[('transaction_type','=','incoming')]"/>
                <filter name="holds" string="Holds" domain="[('transaction_type','in',('allocation_hold','transfer_hold','requisition_hold'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Transaction Type" context="{'group_by':'transaction_type'}"/>
                    <filter name="group_by_account" string="Account" context="{'group_by':'fund_account_id'}"/>
                    <filter name="group_by_project" string="Project" context="{'group_by':'project_id'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_fund_ledger" model="ir.actions.act_window">
        <field name="name">Fund Ledger</field>
        <field name="res_model">nn.fund.ledger</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_fund_ledger_search"/>
        <field name="help" type="html">
            <p>The fund ledger records every financial movement.</p>
            <p>All balances are computed from these entries.</p>
            <p>Posted entries are immutable and cannot be edited or deleted.</p>
        </field>
    </record>
</odoo>
