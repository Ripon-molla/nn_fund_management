<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_nn_incoming_fund_tree" model="ir.ui.view">
        <field name="name">nn.incoming.fund.tree</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="fund_account_id"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="received_date"/>
                <field name="source_type"/>
                <field name="donor_name"/>
                <field name="state"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_nn_incoming_fund_form" model="ir.ui.view">
        <field name="name">nn.incoming.fund.form</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm" invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_verify" type="object"
                            string="Verify" invisible="state != 'pending_verification'"
                            class="btn-primary"
                            groups="group_finance_user,group_fund_administrator"/>
                    <button name="action_reverse" type="object"
                            string="Reverse" invisible="state != 'confirmed'"
                            class="btn-warning"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="reference"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id"/>
                            <field name="amount" widget="monetary"/>
                            <field name="received_date"/>
                            <field name="source_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="donor_name"/>
                            <field name="source_reference"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ledger Info">
                            <group string="Ledger Entries">
                                <field name="ledger_entry_id"/>
                                <field name="reversal_ledger_entry_id"/>
                                <field name="state"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_nn_incoming_fund_search" model="ir.ui.view">
        <field name="name">nn.incoming.fund.search</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="fund_account_id"/>
                <field name="source_type"/>
                <field name="donor_name"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                <filter name="this_month" string="This Month"
                        domain="[('received_date','>=',context_today().replace(day=1))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Account" context="{'group_by':'fund_account_id'}"/>
                    <filter name="group_by_source" string="Source" context="{'group_by':'source_type'}"/>
                    <filter name="group_by_state" string="State" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_nn_incoming_fund" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.incoming.fund</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_incoming_fund_search"/>
        <field name="help" type="html">
            <p>Record all incoming funds to your fund accounts.</p>
            <p>When confirmed, an automatic ledger entry is created.</p>
        </field>
    </record>
</odoo>
