<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fund Ledger Report -->
    <record id="view_nn_fund_ledger_report_pivot" model="ir.ui.view">
        <field name="name">nn.fund.ledger.report.pivot</field>
        <field name="model">nn.fund.ledger</field>
        <field name="arch" type="xml">
            <pivot string="Fund Ledger Report">
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="debit" type="measure" widget="monetary"/>
                <field name="credit" type="measure" widget="monetary"/>
                <field name="transaction_type" type="row"/>
                <field name="fund_account_id" type="row"/>
                <field name="company_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_fund_ledger_report_graph" model="ir.ui.view">
        <field name="name">nn.fund.ledger.report.graph</field>
        <field name="model">nn.fund.ledger</field>
        <field name="arch" type="xml">
            <graph string="Fund Ledger Analysis" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="transaction_type"/>
            </graph>
        </field>
    </record>

    <!-- Allocation Report -->
    <record id="view_nn_fund_allocation_report_pivot" model="ir.ui.view">
        <field name="name">nn.fund.allocation.report.pivot</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <pivot string="Allocation Report">
                <field name="request_date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="state" type="row"/>
                <field name="project_id" type="row"/>
                <field name="fund_account_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_fund_allocation_report_graph" model="ir.ui.view">
        <field name="name">nn.fund.allocation.report.graph</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <graph string="Allocation Analysis" type="bar">
                <field name="request_date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- Requisition Report -->
    <record id="view_nn_fund_requisition_report_pivot" model="ir.ui.view">
        <field name="name">nn.fund.requisition.report.pivot</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <pivot string="Requisition Report">
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="approved_amount" type="measure" widget="monetary"/>
                <field name="remaining_billable_amount" type="measure" widget="monetary"/>
                <field name="state" type="row"/>
                <field name="project_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_fund_requisition_report_graph" model="ir.ui.view">
        <field name="name">nn.fund.requisition.report.graph</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <graph string="Requisition Analysis" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- Transfer Report -->
    <record id="view_nn_fund_transfer_report_pivot" model="ir.ui.view">
        <field name="name">nn.fund.transfer.report.pivot</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <pivot string="Transfer Report">
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="state" type="row"/>
                <field name="source_project_id" type="row"/>
                <field name="destination_project_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_fund_transfer_report_graph" model="ir.ui.view">
        <field name="name">nn.fund.transfer.report.graph</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <graph string="Transfer Analysis" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- Bill Report -->
    <record id="view_nn_fund_bill_report_pivot" model="ir.ui.view">
        <field name="name">nn.fund.bill.report.pivot</field>
        <field name="model">nn.fund.bill</field>
        <field name="arch" type="xml">
            <pivot string="Bill Report">
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="state" type="row"/>
                <field name="project_id" type="row"/>
                <field name="vendor_name" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_fund_bill_report_graph" model="ir.ui.view">
        <field name="name">nn.fund.bill.report.graph</field>
        <field name="model">nn.fund.bill</field>
        <field name="arch" type="xml">
            <graph string="Bill Analysis" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- Approval History Report -->
    <record id="view_nn_approval_history_report_pivot" model="ir.ui.view">
        <field name="name">nn.approval.history.report.pivot</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <pivot string="Approval History Report">
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure" widget="monetary"/>
                <field name="approval_level" type="row"/>
                <field name="new_state" type="row"/>
                <field name="user_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_approval_history_report_graph" model="ir.ui.view">
        <field name="name">nn.approval.history.report.graph</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <graph string="Approval History Analysis" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="approval_level"/>
            </graph>
        </field>
    </record>

    <!-- Project Balance Report -->
    <record id="view_nn_project_report_pivot" model="ir.ui.view">
        <field name="name">nn.project.report.pivot</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <pivot string="Project Balance Report">
                <field name="allocated_amount" type="measure" widget="monetary"/>
                <field name="spent_amount" type="measure" widget="monetary"/>
                <field name="remaining_amount" type="measure" widget="monetary"/>
                <field name="available_balance" type="measure" widget="monetary"/>
                <field name="fund_account_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_project_report_graph" model="ir.ui.view">
        <field name="name">nn.project.report.graph</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <graph string="Project Balance Analysis" type="bar">
                <field name="fund_account_id"/>
                <field name="allocated_amount" type="measure"/>
                <field name="spent_amount" type="measure"/>
                <field name="remaining_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Expense Head Balance Report -->
    <record id="view_nn_expense_head_report_pivot" model="ir.ui.view">
        <field name="name">nn.expense.head.report.pivot</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <pivot string="Expense Head Balance Report">
                <field name="allocated_amount" type="measure" widget="monetary"/>
                <field name="spent_amount" type="measure" widget="monetary"/>
                <field name="remaining_amount" type="measure" widget="monetary"/>
                <field name="project_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_nn_expense_head_report_graph" model="ir.ui.view">
        <field name="name">nn.expense.head.report.graph</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <graph string="Expense Head Balance Analysis" type="bar">
                <field name="project_id"/>
                <field name="allocated_amount" type="measure"/>
                <field name="spent_amount" type="measure"/>
                <field name="remaining_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Report Actions -->
    <record id="action_report_fund_ledger" model="ir.actions.act_window">
        <field name="name">Fund Ledger Report</field>
        <field name="res_model">nn.fund.ledger</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_group_by_transaction_type': 1}</field>
    </record>

    <record id="action_report_allocation" model="ir.actions.act_window">
        <field name="name">Allocation Report</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_requisition" model="ir.actions.act_window">
        <field name="name">Requisition Report</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_transfer" model="ir.actions.act_window">
        <field name="name">Transfer Report</field>
        <field name="res_model">nn.fund.transfer</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_bill" model="ir.actions.act_window">
        <field name="name">Bill Report</field>
        <field name="res_model">nn.fund.bill</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History Report</field>
        <field name="res_model">nn.approval.history</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_project_balance" model="ir.actions.act_window">
        <field name="name">Project Balance Report</field>
        <field name="res_model">nn.project</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <record id="action_report_expense_head_balance" model="ir.actions.act_window">
        <field name="name">Expense Head Balance Report</field>
        <field name="res_model">nn.expense.head</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>
</odoo>
