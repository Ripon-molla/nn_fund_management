<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_project_tree" model="ir.ui.view">
        <field name="name">nn.project.tree</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name"/>
                <field name="fund_account_id"/>
                <field name="allocated_amount" widget="monetary"/>
                <field name="spent_amount" widget="monetary"/>
                <field name="remaining_amount" widget="monetary"/>
                <field name="company_id" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nn_project_form" model="ir.ui.view">
        <field name="name">nn.project.form</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="fund_account_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="is_closed"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group string="Balances">
                        <field name="allocated_amount" widget="monetary"/>
                        <field name="spent_amount" widget="monetary"/>
                        <field name="remaining_amount" widget="monetary" class="text-success"/>
                    </group>
                    <notebook>
                        <page string="Expense Heads">
                            <field name="expense_head_ids" nolabel="1">
                                <list>
                                    <field name="display_name"/>
                                    <field name="allocated_amount" widget="monetary"/>
                                    <field name="spent_amount" widget="monetary"/>
                                    <field name="remaining_amount" widget="monetary"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_project_search" model="ir.ui.view">
        <field name="name">nn.project.search</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="fund_account_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Account" context="{'group_by':'fund_account_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">nn.project</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_project_search"/>
    </record>
</odoo>
