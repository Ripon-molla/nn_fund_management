<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_allocation_tree" model="ir.ui.view">
        <field name="name">nn.fund.allocation.tree</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <list>
                <field name="request_number"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="request_date"/>
                <field name="state"/>
                <field name="requested_by"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nn_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object"
                            string="Submit" invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_approve" type="object"
                            string="Approve" invisible="state != 'pending_approval'"
                            class="btn-success"/>
                    <button name="action_reject" type="object"
                            string="Reject" invisible="state != 'submitted' and state != 'pending_approval'"
                            class="btn-danger"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" invisible="state != 'draft' and state != 'submitted' and state != 'pending_approval'"
                            class="btn-secondary"/>
                    <button name="action_draft" type="object"
                            string="Reset to Draft" invisible="state != 'rejected' and state != 'cancelled'"
                            class="btn-default"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="request_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id"
                                   options="{'no_create': True}"/>
                            <field name="project_id"
                                   options="{'no_create': True}"/>
                            <field name="expense_head_id"
                                   options="{'no_create': True}"
                                   domain="[('project_id','=',project_id)]"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="request_date"/>
                            <field name="requested_by"
                                   options="{'no_create': True}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="purpose" nolabel="1"/>
                    </group>
                    <group>
                        <field name="attachment" filename="attachment_filename"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Requisitions">
                            <field name="requisition_ids" nolabel="1">
                                <list>
                                    <field name="reference"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="state"/>
                                    <field name="billed_amount" widget="monetary"/>
                                    <field name="remaining_billable_amount" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval History">
                            <field name="approval_history_ids" nolabel="1">
                                <list>
                                    <field name="date"/>
                                    <field name="user_id"/>
                                    <field name="approval_level"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ledger Entries">
                            <field name="ledger_entry_ids" nolabel="1">
                                <list>
                                    <field name="date"/>
                                    <field name="transaction_type"/>
                                    <field name="debit" widget="monetary"/>
                                    <field name="credit" widget="monetary"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_allocation_search" model="ir.ui.view">
        <field name="name">nn.fund.allocation.search</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <search>
                <field name="request_number"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="requested_by"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="pending_approval" string="Pending Approval"
                        domain="[('state','in',['submitted','pending_approval'])]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="rejected" string="Rejected" domain="[('state','=','rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_by_project" string="Project" context="{'group_by':'project_id'}"/>
                    <filter name="group_by_account" string="Account" context="{'group_by':'fund_account_id'}"/>
                    <filter name="group_by_requested_by" string="Requested By" context="{'group_by':'requested_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_fund_allocation_search"/>
    </record>
</odoo>
