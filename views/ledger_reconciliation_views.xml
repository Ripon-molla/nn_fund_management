<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_ledger_reconciliation_tree" model="ir.ui.view">
        <field name="name">nn.ledger.reconciliation.tree</field>
        <field name="model">nn.ledger.reconciliation</field>
        <field name="arch" type="xml">
            <list decoration-warning="severity == 'warning'"
                  decoration-danger="severity == 'critical'">
                <field name="date"/>
                <field name="state" widget="badge"/>
                <field name="severity" widget="badge"/>
                <field name="total_accounts"/>
                <field name="accounts_with_issues"/>
                <field name="block_operations" decoration-danger="block_operations == True"/>
                <field name="started_by"/>
                <field name="started_at"/>
                <field name="completed_at"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_nn_ledger_reconciliation_form" model="ir.ui.view">
        <field name="name">nn.ledger.reconciliation.form</field>
        <field name="model">nn.ledger.reconciliation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_reconciliation" type="object"
                            string="Run Reconciliation" invisible="state != 'draft' and state != 'failed'"
                            class="btn-primary"/>
                    <button name="action_view_lines" type="object"
                            string="View Account Details"
                            invisible="state != 'completed'"
                            class="btn-default"/>
                    <button name="action_unblock_operations" type="object"
                            string="Unblock Operations"
                            invisible="state != 'completed' or not block_operations"
                            class="btn-danger"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="started_by"/>
                            <field name="started_at"/>
                            <field name="completed_at"/>
                            <field name="duration_seconds" string="Duration (s)"/>
                        </group>
                    </group>
                    <group string="Results">
                        <group>
                            <field name="total_accounts" string="Accounts Checked"/>
                            <field name="accounts_with_issues" string="Accounts with Issues"/>
                        </group>
                        <group>
                            <field name="severity" widget="badge"/>
                            <field name="block_operations" decoration-danger="block_operations == True"/>
                            <field name="issue_summary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary Report">
                            <field name="summary_html" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Account Details">
                            <field name="line_ids" nolabel="1">
                                <list decoration-warning="severity == 'warning'"
                                      decoration-danger="severity == 'critical'">
                                    <field name="fund_account_id"/>
                                    <field name="stored_current_balance" widget="monetary"/>
                                    <field name="ledger_derived_current_balance" widget="monetary"/>
                                    <field name="has_discrepancy"/>
                                    <field name="negative_balance"/>
                                    <field name="duplicate_count"/>
                                    <field name="missing_entry_count"/>
                                    <field name="orphan_count"/>
                                    <field name="severity" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_ledger_reconciliation_search" model="ir.ui.view">
        <field name="name">nn.ledger.reconciliation.search</field>
        <field name="model">nn.ledger.reconciliation</field>
        <field name="arch" type="xml">
            <search>
                <field name="date"/>
                <field name="state"/>
                <field name="severity"/>
                <filter name="critical" string="Critical"
                        domain="[('severity','=','critical')]"/>
                <filter name="blocked" string="Blocked"
                        domain="[('block_operations','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_by_severity" string="Severity"
                            context="{'group_by': 'severity'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nn_ledger_reconciliation_line_form" model="ir.ui.view">
        <field name="name">nn.ledger.reconciliation.line.form</field>
        <field name="model">nn.ledger.reconciliation.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="fund_account_id"/>
                            <field name="severity" widget="badge"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Balance Comparison">
                            <group>
                                <group string="Stored Balances">
                                    <field name="stored_current_balance" widget="monetary"/>
                                    <field name="stored_held_balance" widget="monetary"/>
                                    <field name="stored_assigned_balance" widget="monetary"/>
                                    <field name="stored_available_balance" widget="monetary"/>
                                    <field name="stored_spent_balance" widget="monetary"/>
                                </group>
                                <group string="Ledger-Derived Balances">
                                    <field name="ledger_derived_current_balance" widget="monetary"/>
                                    <field name="ledger_derived_held_balance" widget="monetary"/>
                                    <field name="ledger_derived_assigned_balance" widget="monetary"/>
                                    <field name="ledger_derived_available_balance" widget="monetary"/>
                                    <field name="ledger_derived_spent_balance" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page string="Issues">
                            <group>
                                <field name="has_discrepancy"/>
                                <field name="negative_balance"/>
                                <field name="duplicate_count"/>
                                <field name="missing_entry_count"/>
                                <field name="orphan_count"/>
                            </group>
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_ledger_reconciliation_line_tree" model="ir.ui.view">
        <field name="name">nn.ledger.reconciliation.line.tree</field>
        <field name="model">nn.ledger.reconciliation.line</field>
        <field name="arch" type="xml">
            <list decoration-warning="severity == 'warning'"
                  decoration-danger="severity == 'critical'">
                <field name="fund_account_id"/>
                <field name="stored_current_balance" widget="monetary"/>
                <field name="ledger_derived_current_balance" widget="monetary"/>
                <field name="has_discrepancy"/>
                <field name="negative_balance"/>
                <field name="duplicate_count"/>
                <field name="missing_entry_count"/>
                <field name="orphan_count"/>
                <field name="severity" widget="badge"/>
                <field name="severity" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_nn_ledger_reconciliation" model="ir.actions.act_window">
        <field name="name">Ledger Reconciliation</field>
        <field name="res_model">nn.ledger.reconciliation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Run your first reconciliation
            </p>
            <p>
                Ledger Reconciliation validates fund account balances against
                ledger-derived values. It detects duplicates, missing entries,
                negative balances, orphan transactions, and mismatches.
            </p>
        </field>
    </record>

</odoo>
