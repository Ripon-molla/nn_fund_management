                  name="Approval History"
                  sequence="10"
                  action="action_nn_approval_history"
                  groups="group_fund_administrator,group_finance_user"/>
        <menuitem id="menu_nn_audit_log"
                  name="Audit Log"
                  sequence="20"
                  action="action_nn_audit_log"
                  groups="group_fund_administrator,group_finance_user"/>
        <menuitem id="menu_nn_bank_email_log"
                  name="Bank Email Log"
                  sequence="30"
