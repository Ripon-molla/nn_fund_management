<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_requisition_tree" model="ir.ui.view">
        <field name="name">nn.fund.requisition.tree</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="approved_amount" widget="monetary" optional="hide"/>
                <field name="billed_amount" widget="monetary" sum="Total Billed"/>
                <field name="remaining_billable_amount" widget="monetary"/>
                <field name="date"/>
                <field name="state"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nn_fund_requisition_form" model="ir.ui.view">
        <field name="name">nn.fund.requisition.form</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object"
                            string="Submit" invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_approve" type="object"
                            string="Approve" invisible="state != 'pending_approval'"
                            class="btn-success"/>
                    <button name="action_reject" type="object"
                            string="Reject" invisible="state != 'submitted' and state != 'pending_approval'"
                            class="btn-danger"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" invisible="state != 'draft' and state != 'submitted' and state != 'pending_approval'"
                            class="btn-secondary"/>
                    <button name="action_close" type="object"
                            string="Close" invisible="state != 'approved'"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="reference"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"
                                    invisible="expense_head_id != False"/>
                            <field name="expense_head_id"
                                    invisible="project_id != False"/>
                            <field name="fund_account_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="approved_amount" widget="monetary"/>
                            <field name="released_amount" widget="monetary"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="billed_amount" widget="monetary"/>
                            <field name="remaining_billable_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bills">
                            <field name="bill_ids" nolabel="1">
                                <list>
                                    <field name="reference"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="state"/>
                                    <field name="date"/>
                                    <field name="vendor_name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ledger Entries">
                            <field name="ledger_entry_ids" nolabel="1">
                                <list>
                                    <field name="date"/>
                                    <field name="reference"/>
                                    <field name="transaction_type"/>
                                    <field name="debit" widget="monetary"/>
                                    <field name="credit" widget="monetary"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_requisition_search" model="ir.ui.view">
        <field name="name">nn.fund.requisition.search</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="pending_approval" string="Pending Approval"
                        domain="[('state','in',['submitted','pending_approval'])]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_by_project" string="Project" context="{'group_by':'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_fund_requisition" model="ir.actions.act_window">
        <field name="name">Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_fund_requisition_search"/>
    </record>
</odoo>
