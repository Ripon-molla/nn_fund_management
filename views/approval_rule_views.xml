<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_approval_rule_tree" model="ir.ui.view">
        <field name="name">nn.approval.rule.tree</field>
        <field name="model">nn.approval.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_type"/>
                <field name="active"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nn_approval_rule_form" model="ir.ui.view">
        <field name="name">nn.approval.rule.form</field>
        <field name="model">nn.approval.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rule Lines">
                            <field name="rule_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="minimum_amount" widget="monetary"/>
                                    <field name="maximum_amount" widget="monetary"/>
                                    <field name="approver_type"/>
                                    <field name="user_id"/>
                                    <field name="group_id"/>
                                    <field name="project_id" optional="show"/>
                                    <field name="expense_head_id" optional="show"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Legacy Steps">
                            <field name="step_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="approver_type"/>
                                    <field name="approver_group_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_approval_rule_search" model="ir.ui.view">
        <field name="name">nn.approval.rule.search</field>
        <field name="model">nn.approval.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="request_type"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Request Type" context="{'group_by':'request_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_approval_rule" model="ir.actions.act_window">
        <field name="name">Approval Rules</field>
        <field name="res_model">nn.approval.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nn_approval_rule_search"/>
    </record>
</odoo>
