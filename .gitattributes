# Auto detect text files and set line endings to LF
* text=auto eol=lf

# Python source
*.py text diff=python
*.xml text
*.csv text
*.js text
*.css text
*.qweb text

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary

# Git LFS for large files
*.sql filter=lfs diff=lfs merge=lfs -text
*.dump filter=lfs diff=lfs merge=lfs -text
